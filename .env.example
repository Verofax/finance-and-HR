# Verofax Finance Platform — environment variables
# Copy to .env.local and fill in. NEVER commit .env.local.

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-NEW-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...your-publishable-key...

# Service-role key — needed for public leave-submit + manager approval flows.
# Supabase Dashboard → Settings → API → "service_role" secret. NEVER commit.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...your-service-role-secret...

# ---- Gmail SMTP (sends leave approval emails) ----
# 1. Pick a Gmail account (e.g. verofax1@gmail.com)
# 2. Enable 2-factor auth on that account
# 3. Generate an App Password at https://myaccount.google.com/apppasswords
#    (Select app: Mail, Device: Other → "Verofax Finance")
# 4. Paste the 16-character password below (spaces don't matter, stripped at runtime)
GMAIL_USER=verofax1@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
GMAIL_FROM_NAME=Verofax Finance

# ---- App URL ----
# Used to build approval links in emails. Use http://localhost:3000 for local dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
