# Verofax Finance Platform — environment variables
# Copy to .env.local and fill in. NEVER commit .env.local.

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-NEW-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...your-publishable-key...

# Service-role key — needed for public leave-submit + manager approval flows.
# Supabase Dashboard → Settings → API → "service_role" secret. NEVER commit.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...your-service-role-secret...

# ---- Resend (email service for leave approval flow) ----
# Sign up free at resend.com → API Keys → Create
RESEND_API_KEY=re_...your-resend-key...
# Optional: custom verified-domain sender. Default falls back to onboarding@resend.dev
# Once you verify finance.verofax.com in Resend, set this to e.g. "Verofax Finance <noreply@verofax.com>"
RESEND_FROM_EMAIL=Verofax Finance <onboarding@resend.dev>

# ---- App URL ----
# Used to build approval links in emails. Use http://localhost:3000 for local dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
